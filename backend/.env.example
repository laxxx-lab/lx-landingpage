# Backend Environment Configuration Template
# Copy this file to .env and configure the values

# Database Connection (PostgreSQL by default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lx_portfolio
# Fallback SQLite format if required:
# DATABASE_URL=sqlite:///./lx_portfolio.db

# JWT secret key for signing admin tokens. Change this to a secure random string in production!
SECRET_KEY=lx_secret_key_change_me_in_production_1234567890

# Default administrator credentials loaded during initial database seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword
